    },
    {
      "name": "2. Kiểm thử AI Agent theo phân quyền (Roles)",
      "item": [
        {
          "name": "Khách hàng (ROLE_USER) - Ước tính cước xe & Đặt xe",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Chào bạn, tôi muốn đi từ Trường Đại học Công nghiệp TPHCM (vĩ độ 10.822, kinh độ 106.687) tới Sân bay Tân Sơn Nhất (vĩ độ 10.815, kinh độ 106.663), hãy tính tiền giúp tôi cho loại xe ECONOMY.\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/ai-agent/chat",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "ai-agent",
                "chat"
              ]
            },
            "description": "Gửi tin nhắn đặt xe dưới vai trò Khách hàng. Agent sẽ kích hoạt Function Calling gọi API Pricing để trả về báo giá thật kèm mã token."
          },
          "response": []
        },
        {
          "name": "Tài xế (ROLE_DRIVER) - Lời khuyên siêu ngắn",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{driverToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Tôi đang lái xe và gặp mưa to gió lớn quá, tôi nên chú ý điều gì lúc này?\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/ai-agent/chat",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "ai-agent",
                "chat"
              ]
            },
            "description": "Gửi câu hỏi dưới vai trò Tài xế. Con AI sẽ phản hồi cực kỳ ngắn gọn (không quá 2 câu), tập trung vào chỉ dẫn an toàn lái xe thực tế."
          },
          "response": []
        },
        {
          "name": "Quản trị viên (ROLE_ADMIN) - Hỗ trợ hệ thống",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Nhiệm vụ chính của bạn với tư cách trợ lý Admin Portal của hệ thống CAB Booking là gì?\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/ai-agent/chat",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "ai-agent",
                "chat"
              ]
            },
            "description": "Gửi câu hỏi dưới vai trò Admin để kiểm chứng thái độ và hệ thống prompt định hướng công việc quản trị."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "customerToken",
      "value": "customer_jwt_token_here",
      "type": "string"
    },
    {
      "key": "driverToken",
      "value": "driver_jwt_token_here",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "admin_jwt_token_here",
      "type": "string"
    }
  ]
