    {
      "name": "1. Xác thực người dùng (Auth)",
      "item": [
        {
          "name": "Đăng ký Khách hàng mới (ROLE_USER)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Khách Hàng Thử Nghiệm\",\n  \"email\": \"khachhang@example.com\",\n  \"password\": \"UserPassword123\",\n  \"phoneNumber\": \"0987654321\",\n  \"role\": \"USER\",\n  \"deviceId\": \"postman_mobile_client\",\n  \"platform\": \"ANDROID\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Đăng ký tài khoản khách hàng mới. Dữ liệu sẽ tự động đồng bộ sang User Service DB."
          },
          "response": []
        },
        {
          "name": "Đăng ký Tài xế mới (ROLE_DRIVER)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Tài Xế Thử Nghiệm\",\n  \"email\": \"taixe@example.com\",\n  \"password\": \"DriverPassword123\",\n  \"phoneNumber\": \"0909090909\",\n  \"role\": \"DRIVER\",\n  \"deviceId\": \"postman_driver_client\",\n  \"platform\": \"ANDROID\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Đăng ký tài khoản tài xế mới. Dữ liệu sẽ tự động đồng bộ sang Driver Service DB."
          },
          "response": []
        },
        {
          "name": "Đăng nhập Tài khoản Admin (System Administrator)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.result && jsonData.result.accessToken) {",
                  "    pm.environment.set(\"adminToken\", jsonData.result.accessToken);",
                  "    pm.collectionVariables.set(\"adminToken\", jsonData.result.accessToken);",
                  "    console.log(\"Captured JWT Admin Token successfully!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cab.local\",\n  \"password\": \"AdminPassword123\",\n  \"deviceId\": \"postman_test_client\",\n  \"platform\": \"POSTMAN\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Đăng nhập tài khoản Admin mặc định được seed sẵn trong hệ thống để tự động lưu Token JWT vào biến môi trường `adminToken`."
          },
          "response": []
        },
        {
          "name": "Đăng nhập Khách hàng (ROLE_USER)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.result && jsonData.result.accessToken) {",
                  "    pm.environment.set(\"customerToken\", jsonData.result.accessToken);",
                  "    pm.collectionVariables.set(\"customerToken\", jsonData.result.accessToken);",
                  "    console.log(\"Captured JWT Customer Token successfully!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"khachhang@example.com\",\n  \"password\": \"UserPassword123\",\n  \"deviceId\": \"postman_mobile_client\",\n  \"platform\": \"ANDROID\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
