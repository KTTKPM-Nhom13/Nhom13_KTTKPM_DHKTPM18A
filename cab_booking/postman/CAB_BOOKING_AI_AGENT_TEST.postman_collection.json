              ]
            },
            "description": "Đăng nhập bằng tài khoản Khách hàng vừa đăng ký."
          },
          "response": []
        },
        {
          "name": "Đăng nhập Tài xế (ROLE_DRIVER)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.result && jsonData.result.accessToken) {",
                  "    pm.environment.set(\"driverToken\", jsonData.result.accessToken);",
                  "    pm.collectionVariables.set(\"driverToken\", jsonData.result.accessToken);",
                  "    console.log(\"Captured JWT Driver Token successfully!\");",
