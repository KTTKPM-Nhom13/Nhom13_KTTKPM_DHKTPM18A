    { "key": "customerBookingKey", "value": "", "type": "string" },
    { "key": "paymentSuccessKey", "value": "", "type": "string" },
    { "key": "paymentFailedKey", "value": "", "type": "string" },
    { "key": "bookingId", "value": "", "type": "string" },
    { "key": "bookingStatus", "value": "", "type": "string" },
    { "key": "successTransactionId", "value": "", "type": "string" },
    { "key": "failedTransactionId", "value": "", "type": "string" }
  ]
}
