					"name": "5. Calculate Simple Price",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Simple price calculated', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('distanceKm');",
									"    pm.expect(jsonData).to.have.property('totalFare');",
									"    pm.test('Total fare is positive', function() {",
									"        pm.expect(parseFloat(jsonData.totalFare)).to.be.above(0);",
									"    });",
									"});"
								],
								"type": "text/javascript"
							}
