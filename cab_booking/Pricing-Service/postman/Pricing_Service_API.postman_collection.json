{
	"info": {
		"_postman_id": "cab-booking-pricing-service",
		"name": "Cab Booking - Pricing Service",
		"description": "Postman collection for testing Cab Booking Pricing Service APIs including authentication",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "authServiceUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "pricingServiceUrl",
			"value": "http://localhost:8084",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "",
			"type": "string"
		},
		{
			"key": "estimateId",
			"value": "",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "0. Auth - Register",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200 || pm.response.code === 201) {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.result && jsonData.result.accessToken) {",
							"        pm.collectionVariables.set('accessToken', jsonData.result.accessToken);",
							"    }",
							"    if (jsonData.result && jsonData.result.refreshToken) {",
							"        pm.collectionVariables.set('refreshToken', jsonData.result.refreshToken);",
							"    }",
							"    if (jsonData.result && jsonData.result.user && jsonData.result.user.userId) {",
							"        pm.collectionVariables.set('userId', jsonData.result.user.userId);",
							"    }",
							"}",
							"",
							"pm.test('Registration successful', function() {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.message).to.include('success');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"testuser{{$timestamp}}@example.com\",\n    \"password\": \"Password123!\",\n    \"fullName\": \"Test User\",\n    \"phoneNumber\": \"+1234567890\",\n    \"deviceId\": \"postman-test-device-{{$timestamp}}\",\n    \"platform\": \"ANDROID\",\n    \"userAgent\": \"Postman/1.0\"\n}"
				},
				"url": {
					"raw": "{{authServiceUrl}}/auth/register",
					"host": ["{{authServiceUrl}}"],
					"path": ["auth", "register"]
				},
				"description": "Register a new user account"
			},
			"response": []
		},
		{
			"name": "1. Auth - Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.result && jsonData.result.accessToken) {",
							"        pm.collectionVariables.set('accessToken', jsonData.result.accessToken);",
							"        pm.test('Access token received', function() {",
							"            pm.expect(jsonData.result.accessToken).to.be.a('string');",
							"        });",
							"    }",
							"    if (jsonData.result && jsonData.result.refreshToken) {",
							"        pm.collectionVariables.set('refreshToken', jsonData.result.refreshToken);",
							"    }",
							"    if (jsonData.result && jsonData.result.user && jsonData.result.user.userId) {",
							"        pm.collectionVariables.set('userId', jsonData.result.user.userId);",
							"    }",
							"}",
							"",
							"pm.test('Login successful', function() {",
							"    pm.expect(pm.response.code).to.eql(200);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.result).to.have.property('accessToken');",
							"    pm.expect(jsonData.result).to.have.property('refreshToken');",
							"    pm.expect(jsonData.result).to.have.property('user');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"testuser@example.com\",\n    \"password\": \"Password123!\",\n    \"deviceId\": \"postman-test-device-001\",\n    \"platform\": \"ANDROID\",\n    \"userAgent\": \"Postman/1.0\"\n}"
				},
				"url": {
					"raw": "{{authServiceUrl}}/auth/login",
					"host": ["{{authServiceUrl}}"],
					"path": ["auth", "login"]
				},
				"description": "Login with existing credentials"
			},
			"response": []
		},
		{
			"name": "2. Auth - Verify Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Token verified', function() {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.result).to.have.property('status', 'success');",
							"    pm.expect(jsonData.result).to.have.property('userId');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"token\": \"{{accessToken}}\"\n}"
				},
				"url": {
					"raw": "{{authServiceUrl}}/auth/verify",
					"host": ["{{authServiceUrl}}"],
					"path": ["auth", "verify"]
				},
				"description": "Verify the JWT token"
			},
			"response": []
		},
		{
			"name": "3. Auth - Refresh Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.result && jsonData.result.accessToken) {",
							"        pm.collectionVariables.set('accessToken', jsonData.result.accessToken);",
							"    }",
							"    if (jsonData.result && jsonData.result.refreshToken) {",
							"        pm.collectionVariables.set('refreshToken', jsonData.result.refreshToken);",
							"    }",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
				},
				"url": {
					"raw": "{{authServiceUrl}}/auth/refresh",
					"host": ["{{authServiceUrl}}"],
					"path": ["auth", "refresh"]
				},
				"description": "Refresh the access token using refresh token"
			},
			"response": []
		},
		{
			"name": "4. Auth - Logout",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Logout successful', function() {",
							"    pm.expect(pm.response.code).to.eql(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\",\n    \"deviceId\": \"postman-test-device-001\"\n}"
				},
				"url": {
					"raw": "{{authServiceUrl}}/auth/logout",
					"host": ["{{authServiceUrl}}"],
					"path": ["auth", "logout"]
				},
				"description": "Logout and invalidate the refresh token"
			},
			"response": []
		},
		{
			"name": "Pricing Service",
