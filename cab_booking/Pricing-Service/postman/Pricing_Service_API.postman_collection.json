					"name": "14. Health Check - Pricing Service",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Pricing service is healthy', function() {",
									"    pm.expect(pm.response.code).to.eql(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql('UP');",
									"});"
